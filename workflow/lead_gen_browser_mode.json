        "url": "https://api.apollo.io/api/v1/contacts/search",
        "sendHeaders": true,
        "specifyHeaders": "json",
        "jsonHeaders": "={{ JSON.stringify({\n  \"Content-Type\": \"application/json\",\n  \"accept\": \"application/json\",\n  \"X-Api-Key\": $env.apollo_api_key || $env.APOLLO_API_KEY || ''\n}) }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  per_page: Number($env.APOLLO_PER_PAGE || 25),\n  q_person_persona_ids: ($env.APOLLO_PERSONA_IDS || '').split(',').map(v => v.trim()).filter(Boolean),\n  person_locations: [$env.APOLLO_COUNTRY || 'United Arab Emirates']\n}) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
