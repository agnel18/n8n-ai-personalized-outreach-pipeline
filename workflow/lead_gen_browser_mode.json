        -880,
        -120
      ],
      "id": "66972b2e-604f-4ea1-b179-16f9f8b28ccf",
      "name": "Apollo Persona Search"
    },
    {
      "parameters": {
        "jsCode": "const contacts = $json.contacts || $json.people || [];\nif (!Array.isArray(contacts) || contacts.length === 0) {\n  throw new Error('Apollo returned no contacts.');\n}\n\nconst firstWithCompany = contacts.find(c => c.organization_name && c.email) || contacts.find(c => c.email) || contacts[0];\nif (!firstWithCompany?.email) {\n  throw new Error('Apollo returned contacts without email.');\n}\n\nconst now = new Date();\nconst pad = (n) => String(n).padStart(2, '0');\nconst runId = `${now.getFullYear()}${pad(now.getMonth()+1)}${pad(now.getDate())}_${pad(now.getHours())}${pad(now.getMinutes())}${pad(now.getSeconds())}`;\n\nconst lead = firstWithCompany;\nlead.organization_name = lead.organization_name || lead.company || 'Unknown Company';\n\nreturn [{\n  json: {\n    run_id: runId,\n    grok_worker_url: $env.GROK_WORKER_URL || 'http://host.docker.internal:8787',\n    status: 'Fetched',\n    operator_action: 'Lead selected. One-company test mode enabled.',\n    updated_at: new Date().toISOString(),\n    lead,\n    raw_apollo_json: JSON.stringify(lead),\n    idempotency_key: `${(lead.email || '').toLowerCase()}_${(lead.organization_name || '').toLowerCase().replace(/[^a-z0-9]+/g,'_')}_${runId.slice(0,8)}`\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -640,
        -120
      ],
      "id": "7a9e1e3b-d6db-4d67-952d-ef354f2f14fd",
