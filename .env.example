# ── Copy to .env and fill in. `docker compose up -d` reads this automatically. ──
# .env is gitignored — never commit real secrets.

# REQUIRED: Postgres password for the bundled database. Set this BEFORE the first
# `docker compose up -d` — it initializes the postgres volume. Changing it after
# the volume exists breaks n8n<->db auth (you'd have to recreate the volume).
POSTGRES_PASSWORD=change_me_before_first_start

# REQUIRED: pin n8n's credential encryption key ONCE so your saved credentials
# (Google Service Account, Gmail) survive container/volume recreation and you
# never have to set them up again. Any long random string works — keep it secret
# and never change it after credentials are created (changing it breaks them).
# Generate one, e.g.:  openssl rand -hex 24
# NOTE: if n8n already ran without this set, it auto-generated a key in the
# n8n_data volume — read it once and paste it here so existing credentials survive:
#   docker exec n8n sh -c 'cat /home/node/.n8n/config'
N8N_ENCRYPTION_KEY=change_me_to_a_long_random_string

# ── XLSX / CSV mode (lead_gen_xlsx_mode.json — no Apollo) ──
# Batch mode is status-based: the workflow reads the tracker sheet, skips leads
# already marked Draft_Created, and processes the next `batch_size` leads. These
# knobs live in the workflow's **Config** node (edit in the n8n UI, no restart):
#   batch_size       how many leads per run (start small, e.g. 5–10)
#   attachment_dir   /home/node/.n8n-files/assets/attachments  (optional; every
#                    file dropped in ./assets/attachments is attached to each draft)
#   email_signature  plain-text signature appended after the email body
#   sender_name      your name (used in the signature)
#   paused           set true to make a run a no-op (soft pause)
#   ai_provider      which worker to call: chatgpt | grok | api (see below)
LEAD_CSV_PATH=/home/node/.n8n-files/leads.csv

# ── AI worker selection ──
# The workflow's Config node has an `ai_provider` field (chatgpt | grok | api) and
# one URL per worker. Each worker has its own default port so they can run at once:
#   chatgpt_worker_url  http://host.docker.internal:8787   (npm run start:chatgpt)
#   grok_worker_url     http://host.docker.internal:8788   (npm start)
#   api_worker_url      http://host.docker.internal:8789   (npm run start:api)
# Start the worker matching ai_provider; override any port with WORKER_PORT.

# ── Browser workers (automation/) ──
# Human-like random wait (ms) before each prompt is sent, so the cadence looks
# less automated. A random value in [MIN, MAX] is used per stage.
GROK_MIN_DELAY_MS=5000
GROK_MAX_DELAY_MS=20000
