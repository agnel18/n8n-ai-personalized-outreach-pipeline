# Copy this file to `.env` (in this automation/ folder) and fill in your values.
# `.env` is gitignored — NEVER commit real API keys.
#
# Node does not auto-load .env. Load it however you prefer, e.g.:
#   - export the vars in your shell before running, or
#   - `node --env-file=.env api_worker.js` (Node 20+), or
#   - prefix a single run:  API_KEY=xai-... npm run start:api

# ─────────────────────────────────────────────────────────────
# Shared
# ─────────────────────────────────────────────────────────────
# Port all workers listen on (must match Config.grok_worker_url in the workflow).
WORKER_PORT=8787

# ─────────────────────────────────────────────────────────────
# API worker  (npm run start:api)
# ─────────────────────────────────────────────────────────────
# OpenAI-compatible chat-completions base URL.
#   xAI Grok:  https://api.x.ai/v1
#   OpenAI:    https://api.openai.com/v1
API_BASE_URL=https://api.x.ai/v1

# Your API key (xAI key from https://console.x.ai, or an OpenAI key).
API_KEY=

# Model id.  xAI: grok-4.3   |   OpenAI: gpt-4o (or a *-search-preview model for web search)
MODEL=grok-4.3

# Controls how web search is wired: xai | openai | generic
API_PROVIDER=xai

# Live web search — applied to the RESEARCH stage only (review/final_email don't search).
#   xai:    fully supported (Live Search).
#   openai: best-effort (needs a search-capable model); otherwise ignored.
ENABLE_WEB_SEARCH=true

# Per-request timeout in ms (research + search can be slow).
API_TIMEOUT_MS=180000

# ─────────────────────────────────────────────────────────────
# Browser workers  (npm run start:chatgpt  /  npm start)
# ─────────────────────────────────────────────────────────────
# ChatGPT worker
CHATGPT_URL=https://chatgpts.site/
CHATGPT_PROFILE_DIR=./.chatgpt-profile
CHATGPT_STABLE_MS=3500
CHATGPT_MIN_DELAY_MS=5000
CHATGPT_MAX_DELAY_MS=20000

# Grok worker
GROK_URL=https://grok2.testingg.in/
GROK_PROFILE_DIR=./.grok-profile

# Optional path overrides (default: repo root for prompts, docs/output for results)
# REPO_ROOT=..
# OUTPUT_ROOT=../docs/output
