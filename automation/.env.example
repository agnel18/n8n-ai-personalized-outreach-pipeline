# =============================================================================

# OpenAI API Worker Configuration

# =============================================================================
#
# This file is a SAFE TEMPLATE.
# Do not place a real API key in .env.example.
# Users must copy this file to a new file named ".env" and place their key there.
#
# PowerShell:
# Copy-Item .env.example .env
#
# macOS / Linux:
# cp .env.example .env
#
# Then open ".env" and replace the placeholder API key.
#
# Never commit the real ".env" file to Git.

# =============================================================================
# -----------------------------------------------------------------------------
# Provider
# -----------------------------------------------------------------------------
#
# This release currently supports the OpenAI API provider only.
#
API_PROVIDER=openai
# -----------------------------------------------------------------------------
# OpenAI API key
# -----------------------------------------------------------------------------
#
# Required.
#
# Create an OpenAI API key from the OpenAI API platform and paste it into the
# private ".env" file.
#
# Example:
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx
#
# Leave this blank in .env.example.
#
OPENAI_API_KEY=
# -----------------------------------------------------------------------------
# OpenAI API base URL
# -----------------------------------------------------------------------------
#
# Normally, users should not change this value.
#
OPENAI_BASE_URL=https://api.openai.com/v1
# -----------------------------------------------------------------------------
# OpenAI model
# -----------------------------------------------------------------------------
#

# The model used for:
# 1. Company and lead research
# 2. Research review
# 3. Final personalized email generation
#

# The research stage can use OpenAI's web_search tool when
# ENABLE_WEB_SEARCH=true.
#
# This value matches the currently tested default in this repository.
#

OPENAI_MODEL=gpt-5.5

# -----------------------------------------------------------------------------
# Web search
# -----------------------------------------------------------------------------
#
# true:
# Stage 1 may search the public web for current company and lead information.
#
# false:
# Stage 1 uses only the lead information already supplied by the workflow.
#
# Web search is enabled only for the research stage. Review and final-email
# stages do not perform additional searches.
#
ENABLE_WEB_SEARCH=true

# -----------------------------------------------------------------------------
# API request timeout
# -----------------------------------------------------------------------------
#
# Maximum time, in milliseconds, allowed for an OpenAI generation request.
#
# 165000 milliseconds = 165 seconds.
#
# This should remain lower than the timeout configured in the n8n HTTP Request
# nodes so the worker can return a controlled timeout error before n8n aborts.

#

API_TIMEOUT_MS=165000
# -----------------------------------------------------------------------------
# Configuration-validation timeout
# -----------------------------------------------------------------------------
#

# Maximum time, in milliseconds, allowed when checking the API key and selected
# model through the health or session-check endpoints.
#

API_VALIDATION_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Worker network configuration
# -----------------------------------------------------------------------------

#
# Default API worker port:
#

API_WORKER_PORT=8789
#
# Bind to all IPv4 interfaces so an n8n Docker container can reach the worker
# through host.docker.internal.
#
WORKER_HOST=0.0.0.0
